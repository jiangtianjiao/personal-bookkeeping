{
  "name": "backend",
  "version": "1.0.0",
  "description": "Personal Bookkeeping Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --accept-data-loss",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:init": "prisma db push --accept-data-loss && ts-node prisma/seed.ts",
    "setup": "npm install && npx prisma generate && npm run db:init"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.4.24",
    "imapflow": "^1.3.1",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.8",
    "multer": "^2.1.1",
    "read-excel-file": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.3",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.5.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.11.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
